# Set your real domain name
DOMAIN=memory.example.com

# Let's Encrypt contact email
ACME_EMAIL=admin@example.com

# HTTP Basic auth username
BASIC_AUTH_USER=memoryadmin

# BCrypt hash generated with:
# docker run --rm caddy:2.8 caddy hash-password --plaintext "your-strong-password"
BASIC_AUTH_HASH=$2a$14$replace_this_with_real_bcrypt_hash

# Backup retention in days
BACKUP_RETENTION_DAYS=14