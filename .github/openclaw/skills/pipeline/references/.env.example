# =============================================================================
# Pipeline Proxy — .env példa
# Másold .env-re és töltsd ki a kulcsokat!
# =============================================================================

# ═══ Proxy beállítások ═══
LITELLM_MASTER_KEY=sk-master-itt-a-te-titkos-kulcsod
DATABASE_URL=sqlite:///data/litellm.db

# ═══ NVIDIA NIM (build.nvidia.com) ═══
# Regisztráció: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-ide-ird-az-nvidia-kulcsot

# ═══ OpenRouter ═══
# Kulcs: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-ide-ird-az-openrouter-kulcsot

# ═══ Google Gemini ═══
# Kulcs: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy-ide-ird-az-gemini-kulcsot

# ═══ SambaNova ═══
# Regisztráció: https://cloud.sambanova.ai/
SAMBANOVA_API_KEY=sambanova-ide-ird-az-sambanova-kulcsot

# ═══ Opcionális: Monitoring ═══
# LITELLM_SALT_KEY=random-salt-a-kulcsok-titkositasahoz
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
